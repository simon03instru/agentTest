# /etc/nginx/sites-available/station-monitor
#
# Konfigurasi Nginx untuk deploy frontend + proxy ke FastAPI backend
# di satu VM yang sama.
#
# Cara pakai:
#   sudo ln -s /etc/nginx/sites-available/station-monitor /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    server_name your-domain.com;   # ganti dengan domain/IP VM kamu

    # ─── Frontend React (build output) ──────────────────────────────────
    root /var/www/station-dashboard/dist;
    index index.html;

    # SPA fallback: semua route diteruskan ke index.html
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Cache static assets dengan agresif
    location ~* \.(js|css|png|jpg|svg|ico|woff2?)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # ─── Backend FastAPI (reverse proxy) ────────────────────────────────
    location /api/ {
        proxy_pass         http://127.0.0.1:8000/;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;

        # CORS headers (opsional jika FastAPI sudah handle sendiri)
        # add_header Access-Control-Allow-Origin *;
    }

    # Gzip compression
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml;
    gzip_min_length 1000;
}
